{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_GATEWAY_URL": "https://staging-gateway.livsight.com",
        "EXPO_PUBLIC_ENABLE_PUSH": "true",
        "EXPO_PUBLIC_MESSAGING_ENABLED": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_GATEWAY_URL": "https://gateway.livsight.com",
        "EXPO_PUBLIC_ENABLE_PUSH": "true",
        "EXPO_PUBLIC_MESSAGING_ENABLED": "false"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "$GOOGLE_PLAY_SERVICE_ACCOUNT_KEY",
        "track": "internal"
      }
    }
  }
}