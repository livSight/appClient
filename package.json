    "expo": "^56.0.0",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
