{
  "name": "appclient",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go",
    "start:sim": "expo start --go --localhost",
    "start:dev": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "eas:build:dev:android": "npx eas-cli build --profile development --platform android",
    "eas:build:dev:ios": "npx eas-cli build --profile development --platform ios",
    "eas:build:preview:android": "npx eas-cli build --profile preview --platform android",
    "eas:build:preview:ios": "npx eas-cli build --profile preview --platform ios",
    "eas:build:production": "npx eas-cli build --profile production --platform all"
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo-google-fonts/palanquin": "^0.4.1",
